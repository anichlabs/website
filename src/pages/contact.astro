---
import Contactform from "@/components/contactform.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout title="Contact">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Contact</Fragment>
      <Fragment slot="desc">Let's talk about your project.</Fragment>
    </Sectionhead>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-16">

      <!-- Left column -->
      <div>
        <h2 class="font-medium text-2xl text-gray-800">Get in Touch</h2>
        <p class="text-lg leading-relaxed text-slate-500 mt-3">
          Have a project in mind? Send us a message or book a free 30-minute
          discovery call - no commitment required.
        </p>



        <!-- Elegant Book a Call CTA -->
        <div class="mt-10 relative overflow-hidden rounded-2xl bg-gradient-to-br from-indigo-600 to-violet-600 p-px">
          <div class="rounded-2xl bg-gradient-to-br from-indigo-600 to-violet-600 p-6">
            <!-- Decorative circles -->
            <div class="absolute -top-6 -right-6 w-32 h-32 rounded-full bg-white opacity-5"></div>
            <div class="absolute -bottom-8 -left-4 w-24 h-24 rounded-full bg-white opacity-5"></div>

            <p class="text-xs font-semibold uppercase tracking-widest text-indigo-200 mb-2">Free · 30 minutes · Zoom</p>
            <h3 class="font-bold text-white text-xl leading-snug">
              Book a Free<br/>Discovery Call
            </h3>
            <p class="text-indigo-100 text-sm mt-2 leading-relaxed">
              We'll discuss your project, clarify your needs,
              and outline how AnichLabs can help — no commitment required.
            </p>
            <a
              href="https://calendly.com/chris-anichlabs/30min"
              target="_blank"
              rel="noopener"
              class="mt-5 inline-flex items-center gap-2 bg-white text-indigo-700 hover:bg-indigo-50 font-semibold text-sm px-5 py-3 rounded-xl transition-colors shadow-sm">
              <Icon class="w-4 h-4" name="uil:calendar-alt" />
              Schedule a Call
              <Icon class="w-4 h-4 ml-1" name="uil:arrow-right" />
            </a>
          </div>
        </div>

      </div>

      <!-- Right column: form -->
      <div>
        <Contactform />
      </div>

    </div>
  </Container>
</Layout>