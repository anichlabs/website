---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site
).toString();

const { title } = Astro.props;

const makeTitle = title
  ? title + " | " + "AnichLabs OÜ"
  : "AnichLabs OÜ - AI & Data Solutions for Healthcare and Startups";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={makeTitle}
      description="AnichLabs helps healthcare professionals, startups, and small teams leverage AI, data analytics, and smart apps to improve outcomes and streamline operations."
      canonical={canonicalURL}
      twitter={{
        creator: "@chrisanich",
        site: "@anichlabs",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: `AnichLabs OÜ — AI & Data Solutions for Healthcare and Startups`,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "AnichLabs OÜ Homepage",
        },
      }}
    />
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
    <style is:global>
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
