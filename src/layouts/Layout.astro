---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import "@fontsource-variable/inter/index.css";
// @ts-ignore
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/og-preview.jpg",
  Astro.site
).toString();

const { title, description } = Astro.props;

const makeTitle = title
  ? title + " | " + "AnichLabs"
  : "AnichLabs | Intelligent Systems";

const defaultDescription = "AnichLabs is a European software and AI company building intelligent systems where privacy, compliance, and reliability matter. We work with clinics, regulated businesses, and ambitious founders across Europe and Latin America.";

const pageDescription = description || defaultDescription;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/anichlabs_logo_full.png" />
    <link rel="apple-touch-icon" href="/anichlabs_logo_full.png" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={makeTitle}
      description={pageDescription}
      canonical={canonicalURL}
      twitter={{
        creator: "@chrisanich",
        site: "@anichlabs",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: makeTitle,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "AnichLabs OÜ - Intelligent Systems for Serious Businesses",
        },
      }}
    />
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
    <style is:global>
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
