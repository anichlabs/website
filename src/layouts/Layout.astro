---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import "@fontsource-variable/inter/index.css";
// @ts-ignore
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/anichlabs_logo_full.png",
  Astro.site
).toString();

const { title } = Astro.props;

const makeTitle = title
  ? title + " | " + "AnichLabs OÜ"
  : "AnichLabs OÜ - AI and Software Lab for Healthcare and Regulated Industries";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/anichlabs_logo_full.png" />
    <link rel="apple-touch-icon" href="/anichlabs_logo_full.png" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={makeTitle}
      description="AnichLabs is an Estonian AI and software lab working across Europe and Latin America. Founded by a medical doctor and computer scientist, we build intelligent systems for healthcare and regulated industries."
      canonical={canonicalURL}
      twitter={{
        creator: "@chrisanich",
        site: "@anichlabs",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: `AnichLabs OÜ - AI and Software Lab for Healthcare and Regulated Industries`,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "AnichLabs OÜ Homepage",
        },
      }}
    />
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
    <style is:global>
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
