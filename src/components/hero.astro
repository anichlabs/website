---
import Link from "@/components/ui/link.astro";
import { Icon } from "astro-icon/components";
---

<main class="relative">

  <div class="grid lg:grid-cols-2 place-items-center pt-16 pb-8 md:pt-12 md:pb-24">

    <!-- Right: 3D globe -->
    <div class="py-6 md:order-1 flex items-center justify-center w-full">
      <div id="anichlabs-globe" class="relative w-full max-w-[460px] h-[460px] opacity-0 transition-opacity duration-700 ease-out"></div>
    </div>

    <!-- Left: text content -->
    <div>
      <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: #003399">
        Estonia · Europe · Latin America
      </p>
      <h1 class="text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter">
        Intelligent systems for <span style="color: #003399">healthcare and compliance</span>
      </h1>
      <p class="text-lg mt-4 text-slate-600 max-w-xl">
        AnichLabs is an Estonian AI and software lab working across Europe and
        Latin America. Founded by a medical doctor and computer scientist, we
        build intelligent systems for healthcare and compliance work.
      </p>
      <ul class="mt-5 space-y-1 text-sm text-slate-500 max-w-md">
        <li class="flex items-center gap-2">
          <Icon name="uil:check-circle" class="w-4 h-4 shrink-0" style="color: #003399" />
          AI agents, automation, and clinical AI systems
        </li>
        <li class="flex items-center gap-2">
          <Icon name="uil:check-circle" class="w-4 h-4 shrink-0" style="color: #003399" />
          EU regulatory expertise: EU AI Act, MDR, IVDR, and GDPR
        </li>
        <li class="flex items-center gap-2">
          <Icon name="uil:check-circle" class="w-4 h-4 shrink-0" style="color: #003399" />
          Digital platforms for clinics and health-tech companies
        </li>
      </ul>
      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <Link
          href="https://calendly.com/chris-anichlabs/30min"
          target="_blank"
          rel="noopener"
          class="flex gap-1 items-center justify-center">
          <Icon class="text-white w-5 h-5" name="uil:calendar-alt" />
          Book a Free Discovery Call
        </Link>
        <Link
          size="lg"
          style="outline"
          href="#services"
          class="flex gap-1 items-center justify-center">
          <Icon class="text-black w-4 h-4" name="uil:arrow-down" />
          See What We Do
        </Link>
      </div>
      <p class="mt-6 text-xs text-slate-400">
        EU-registered. Working with clients across Europe and Latin America.
      </p>
    </div>

  </div>
</main>

<script src="/lib/three.min.js" is:inline></script>
<script is:inline>
(async function() {
  const container = document.getElementById('anichlabs-globe');
  if (!container) return;
  const width = container.clientWidth;
  const height = container.clientHeight;

  let landPositions;
  try {
    const res = await fetch('/lib/globe-dots.json');
    landPositions = await res.json();
  } catch (e) {
    return;
  }

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000);
  camera.position.z = 5;

  const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
  renderer.setSize(width, height);
  renderer.setPixelRatio(window.devicePixelRatio);
  container.appendChild(renderer.domElement);

  const globeGroup = new THREE.Group();
  scene.add(globeGroup);
  const radius = 1.5;

  const innerGeo = new THREE.SphereGeometry(radius * 0.985, 64, 48);
  const innerMat = new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.92 });
  globeGroup.add(new THREE.Mesh(innerGeo, innerMat));

  function latLonToVec3(lat, lon, r) {
    const phi = (90 - lat) * Math.PI / 180;
    const theta = (lon + 180) * Math.PI / 180;
    return new THREE.Vector3(
      -r * Math.sin(phi) * Math.cos(theta),
      r * Math.cos(phi),
      r * Math.sin(phi) * Math.sin(theta)
    );
  }

  const landGeo = new THREE.BufferGeometry();
  landGeo.setAttribute('position', new THREE.Float32BufferAttribute(landPositions, 3));
  const landMat = new THREE.PointsMaterial({ color: 0x003399, size: 0.016, transparent: true, opacity: 0.7 });
  globeGroup.add(new THREE.Points(landGeo, landMat));

  const euNodes = [
    { name: 'Tallinn', lat: 59.4370, lon: 24.7536, primary: true },
    { name: 'Dublin', lat: 53.3498, lon: -6.2603, primary: true },
    { name: 'Berlin', lat: 52.5200, lon: 13.4050 },
    { name: 'Paris', lat: 48.8566, lon: 2.3522 },
    { name: 'Madrid', lat: 40.4168, lon: -3.7038 },
    { name: 'Amsterdam', lat: 52.3676, lon: 4.9041 }
  ];
  const chlNodes = [
    { name: 'Santiago', lat: -33.4489, lon: -70.6693, primary: true },
    { name: 'Valparaiso', lat: -33.0472, lon: -71.6127 },
    { name: 'Concepcion', lat: -36.8270, lon: -73.0498 },
    { name: 'Antofagasta', lat: -23.6509, lon: -70.3975 },
    { name: 'Puerto Montt', lat: -41.4693, lon: -72.9424 }
  ];
  const allNodes = euNodes.concat(chlNodes);

  const markers = [];
  allNodes.forEach(function(n) {
    const pos = latLonToVec3(n.lat, n.lon, radius);
    const size = n.primary ? 0.045 : 0.028;
    const inner = new THREE.Mesh(
      new THREE.SphereGeometry(size, 12, 12),
      new THREE.MeshBasicMaterial({ color: 0x003399 })
    );
    inner.position.copy(pos);
    globeGroup.add(inner);

    const ring = new THREE.Mesh(
      new THREE.RingGeometry(size * 1.5, size * 1.8, 32),
      new THREE.MeshBasicMaterial({ color: 0x003399, transparent: true, opacity: 0.7, side: THREE.DoubleSide })
    );
    ring.position.copy(pos);
    ring.lookAt(0, 0, 0);
    globeGroup.add(ring);

    const pulseRing = new THREE.Mesh(
      new THREE.RingGeometry(size * 1.5, size * 1.7, 32),
      new THREE.MeshBasicMaterial({ color: 0x003399, transparent: true, opacity: 0.5, side: THREE.DoubleSide })
    );
    pulseRing.position.copy(pos);
    pulseRing.lookAt(0, 0, 0);
    globeGroup.add(pulseRing);

    markers.push({ pos: pos, ring: ring, pulseRing: pulseRing, primary: n.primary, phase: Math.random() * Math.PI * 2, lon: n.lon });
  });

  const intraEuArcs = [
    [euNodes[0], euNodes[2]],
    [euNodes[1], euNodes[3]],
    [euNodes[2], euNodes[3]],
    [euNodes[3], euNodes[4]],
    [euNodes[2], euNodes[5]],
    [euNodes[5], euNodes[1]]
  ];
  const intraChlArcs = [
    [chlNodes[0], chlNodes[1]],
    [chlNodes[0], chlNodes[2]],
    [chlNodes[0], chlNodes[3]],
    [chlNodes[2], chlNodes[4]],
    [chlNodes[3], chlNodes[1]]
  ];
  const allArcs = intraEuArcs.concat(intraChlArcs);

  const arcLines = [];
  allArcs.forEach(function(pair) {
    const a = latLonToVec3(pair[0].lat, pair[0].lon, radius);
    const b = latLonToVec3(pair[1].lat, pair[1].lon, radius);
    const distance = a.distanceTo(b);
    const arcHeight = Math.min(0.25, distance * 0.3);
    const mid = a.clone().add(b).multiplyScalar(0.5);
    mid.normalize().multiplyScalar(radius + arcHeight);
    const curve = new THREE.QuadraticBezierCurve3(a, mid, b);
    const points = curve.getPoints(40);
    const geo = new THREE.BufferGeometry().setFromPoints(points);
    const mat = new THREE.LineBasicMaterial({ color: 0x003399, transparent: true, opacity: 0.45 });
    const line = new THREE.Line(geo, mat);
    globeGroup.add(line);

    const dotGeo = new THREE.BufferGeometry();
    dotGeo.setAttribute('position', new THREE.Float32BufferAttribute([0, 0, 0], 3));
    const dot = new THREE.Points(dotGeo, new THREE.PointsMaterial({ color: 0x003399, size: 0.06 }));
    globeGroup.add(dot);
    arcLines.push({ points: points, dot: dot, progress: Math.random() });
  });

  const orbitalCount = 42;
  const orbitalRadius = radius * 1.35;
  const orbitalGeo = new THREE.BufferGeometry();
  const orbitalPositions = new Float32Array(orbitalCount * 3);
  const orbitalData = [];
  for (let i = 0; i < orbitalCount; i++) {
    const lat = (Math.random() - 0.5) * 120;
    const lon = (Math.random() - 0.5) * 360;
    orbitalData.push({ lat: lat, lon: lon, speed: 0.0008 + Math.random() * 0.0012 });
    const v = latLonToVec3(lat, lon, orbitalRadius);
    orbitalPositions[i * 3] = v.x;
    orbitalPositions[i * 3 + 1] = v.y;
    orbitalPositions[i * 3 + 2] = v.z;
  }
  orbitalGeo.setAttribute('position', new THREE.BufferAttribute(orbitalPositions, 3));
  const orbitalMat = new THREE.PointsMaterial({ color: 0x003399, size: 0.04, transparent: true, opacity: 0.7 });
  globeGroup.add(new THREE.Points(orbitalGeo, orbitalMat));

  const scanGeo = new THREE.RingGeometry(radius * 0.99, radius * 1.005, 64);
  const scanMat = new THREE.MeshBasicMaterial({ color: 0x003399, transparent: true, opacity: 0.25, side: THREE.DoubleSide });
  const scanRing = new THREE.Mesh(scanGeo, scanMat);
  scanRing.rotation.x = Math.PI / 2;
  globeGroup.add(scanRing);

  globeGroup.rotation.x = 0.22;
  globeGroup.rotation.y = -2.7;

  function findClosestMarker(rotationY) {
    let bestDist = Infinity;
    let bestZ = -Infinity;
    for (let i = 0; i < markers.length; i++) {
      const original = latLonToVec3(0, markers[i].lon, radius);
      const cosY = Math.cos(rotationY);
      const sinY = Math.sin(rotationY);
      const rotatedX = original.x * cosY + original.z * sinY;
      const rotatedZ = -original.x * sinY + original.z * cosY;
      if (rotatedZ > -0.3) {
        const dist = Math.abs(rotatedX);
        if (dist < bestDist) {
          bestDist = dist;
          bestZ = rotatedZ;
        }
      }
    }
    if (bestZ < -0.3) return 0;
    const visibility = Math.max(0, (bestZ + 0.3) / (radius + 0.3));
    const proximity = 1 - Math.min(1, bestDist / (radius * 1.3));
    return Math.min(1, Math.pow(visibility * proximity, 0.7) * 1.6);
  }

  let smoothedInterest = 0;
  let pulsePhase = 0;
  let scanProgress = 0;

  function animate() {
    requestAnimationFrame(animate);
    const targetInterest = findClosestMarker(globeGroup.rotation.y);
    smoothedInterest += (targetInterest - smoothedInterest) * 0.04;
    const slowSpeed = 0.0025;
    const fastSpeed = 0.030;
    const speed = slowSpeed + (fastSpeed - slowSpeed) * Math.pow(1 - smoothedInterest, 2);
    globeGroup.rotation.y += speed;

    pulsePhase += 0.05;
    markers.forEach(function(m) {
      const localPhase = pulsePhase + m.phase;
      const pulse = 1 + Math.sin(localPhase) * (m.primary ? 0.25 : 0.15);
      m.ring.scale.set(pulse, pulse, pulse);
      const expandPhase = (localPhase * 0.5) % (Math.PI * 2);
      const expand = 1 + (expandPhase / (Math.PI * 2)) * 2.5;
      const fade = 1 - (expandPhase / (Math.PI * 2));
      m.pulseRing.scale.set(expand, expand, expand);
      m.pulseRing.material.opacity = fade * 0.5;
    });

    arcLines.forEach(function(a) {
      a.progress += 0.006;
      if (a.progress > 1) a.progress = 0;
      const idx = Math.floor(a.progress * (a.points.length - 1));
      const p = a.points[idx];
      a.dot.geometry.attributes.position.array[0] = p.x;
      a.dot.geometry.attributes.position.array[1] = p.y;
      a.dot.geometry.attributes.position.array[2] = p.z;
      a.dot.geometry.attributes.position.needsUpdate = true;
    });

    for (let i = 0; i < orbitalCount; i++) {
      orbitalData[i].lon += orbitalData[i].speed * 60;
      if (orbitalData[i].lon > 180) orbitalData[i].lon -= 360;
      const v = latLonToVec3(orbitalData[i].lat, orbitalData[i].lon, orbitalRadius);
      orbitalPositions[i * 3] = v.x;
      orbitalPositions[i * 3 + 1] = v.y;
      orbitalPositions[i * 3 + 2] = v.z;
    }
    orbitalGeo.attributes.position.needsUpdate = true;

    scanProgress += 0.005;
    if (scanProgress > 1) scanProgress = 0;
    const scanY = (scanProgress - 0.5) * 2 * radius;
    scanRing.position.y = scanY;
    const scanRadius = Math.sqrt(Math.max(0, radius * radius - scanY * scanY));
    scanRing.scale.set(scanRadius / (radius * 0.99), scanRadius / (radius * 0.99), 1);
    scanRing.material.opacity = (1 - Math.abs(scanProgress - 0.5) * 2) * 0.3;

    renderer.render(scene, camera);
  }
  animate();
  requestAnimationFrame(function() {
    container.style.opacity = '1';
  });

  window.addEventListener('resize', function() {
    const w = container.clientWidth;
    const h = container.clientHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
  });
})();
</script>