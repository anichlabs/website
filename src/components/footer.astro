---
import Container from "@/components/container.astro";
---

<footer class="bg-slate-50 border-t border-slate-200 mt-20">
  <Container>
    <div class="py-16 grid grid-cols-1 md:grid-cols-4 gap-10">

      <!-- Brand Column -->
      <div class="col-span-1 md:col-span-2">
        <a href="/" class="text-lg">
          <span class="font-bold text-slate-800">Anich</span><span
            class="text-indigo-600">Labs</span
          ><span class="text-slate-400 text-sm font-normal ml-0.5">OÜ</span>
        </a>
        <p class="mt-4 text-slate-500 text-sm max-w-xs leading-relaxed">
          Compliance partner for health-tech companies entering the European market.
          EU Authorised Representative, GDPR, EU AI Act, and MDR in one place.
        </p>
        <div class="mt-5 flex gap-4">
          <a
            href="https://linkedin.com/company/anichlabs"
            target="_blank"
            rel="noopener"
            class="text-slate-400 hover:text-[#003399] transition-colors"
            aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
          <a
            href="mailto:contact@anichlabs.com"
            class="text-slate-400 hover:text-[#003399] transition-colors"
            aria-label="Email">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Services Column -->
      <div>
        <h3 class="font-semibold text-slate-800 mb-4">Services</h3>
        <ul class="space-y-2 text-sm text-slate-500">
          <li><a href="/services/eu-authorised-representative" class="hover:text-[#003399] transition-colors">EU Authorised Representative</a></li>
          <li><a href="/services/eu-ai-act-mdr-compliance" class="hover:text-[#003399] transition-colors">EU AI Act & MDR Compliance</a></li>
          <li><a href="/services/gdpr-advisory" class="hover:text-[#003399] transition-colors">GDPR Advisory</a></li>
          <li><a href="/services/clinical-ai-strategy" class="hover:text-[#003399] transition-colors">Clinical AI Strategy</a></li>
          <li><a href="/services/data-analytics" class="hover:text-[#003399] transition-colors">Data Science & Analytics</a></li>
          <li><a href="/services/app-development" class="hover:text-[#003399] transition-colors">App Development</a></li>
        </ul>
      </div>

      <!-- Company Column -->
      <div>
        <h3 class="font-semibold text-slate-800 mb-4">Company</h3>
        <ul class="space-y-2 text-sm text-slate-500">
          <li><a href="/about" class="hover:text-[#003399] transition-colors">About</a></li>
          <li><a href="/blog" class="hover:text-[#003399] transition-colors">Blog</a></li>
          <li><a href="/contact" class="hover:text-[#003399] transition-colors">Contact</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-slate-200 py-6 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-sm text-slate-400">
        © {new Date().getFullYear()} AnichLabs OÜ. All rights reserved.
      </p>
      <p class="text-sm text-slate-400">
        Registered in Estonia, EU 🇪🇪 · Remote-first
      </p>
    </div>

  </Container>
</footer>