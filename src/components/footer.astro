---
import Container from "@/components/container.astro";
---

<footer class="bg-slate-50 border-t border-slate-200 mt-20">
  <Container>
    <div class="py-16 grid grid-cols-1 md:grid-cols-4 gap-10">

      <!-- Brand Column -->
      <div class="col-span-1 md:col-span-2">
        <a href="/" class="text-lg">
          <span class="font-bold text-slate-800">Anich</span><span
            class="text-indigo-600">Labs</span
          ><span class="text-slate-400 text-sm font-normal ml-0.5">OÜ</span>
        </a>
        <p class="mt-4 text-slate-500 text-sm max-w-xs leading-relaxed">
          AI & Data Solutions for Healthcare and Startups. We help teams
          leverage AI, data analytics, and smart apps to improve outcomes
          and streamline operations.
        </p>
        <div class="mt-5 flex gap-4">
          <a
            href="https://github.com/chrisanich"
            target="_blank"
            rel="noopener"
            class="text-slate-400 hover:text-indigo-600 transition-colors"
            aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
          </a>
          <a
            href="https://linkedin.com/in/company/anichlabs/"
            target="_blank"
            rel="noopener"
            class="text-slate-400 hover:text-indigo-600 transition-colors"
            aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Services Column -->
      <div>
        <h3 class="font-semibold text-slate-800 mb-4">Services</h3>
        <ul class="space-y-2 text-sm text-slate-500">
          <li><a href="/services#ai-consulting" class="hover:text-indigo-600 transition-colors">AI Consulting</a></li>
          <li><a href="/services#app-development" class="hover:text-indigo-600 transition-colors">App Development</a></li>
          <li><a href="/services#data-analytics" class="hover:text-indigo-600 transition-colors">Data Analytics</a></li>
          <li><a href="/services#web-email" class="hover:text-indigo-600 transition-colors">Website & Email Setup</a></li>
        </ul>
      </div>

      <!-- Company Column -->
      <div>
        <h3 class="font-semibold text-slate-800 mb-4">Company</h3>
        <ul class="space-y-2 text-sm text-slate-500">
          <li><a href="/about" class="hover:text-indigo-600 transition-colors">About</a></li>
          <li><a href="/blog" class="hover:text-indigo-600 transition-colors">Blog</a></li>
          <li><a href="/pricing" class="hover:text-indigo-600 transition-colors">Pricing</a></li>
          <li><a href="/contact" class="hover:text-indigo-600 transition-colors">Contact</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-slate-200 py-6 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-sm text-slate-400">
        © {new Date().getFullYear()} AnichLabs OÜ. All rights reserved.
      </p>
      <p class="text-sm text-slate-400">
        Tallinn, Estonia
      </p>
    </div>

  </Container>
</footer>