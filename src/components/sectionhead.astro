---
const { align = "center" } = Astro.props;
---

<div class:list={["mt-16 relative", align === "center" && "text-center"]}>

  <!-- Top thin accent line -->
  <div class="flex justify-center mb-6">
    <div class="h-px w-full max-w-3xl" style="background: linear-gradient(90deg, transparent, #003399, transparent);"></div>
  </div>

  <h1 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    <slot name="title">Title</slot>
  </h1>
  <p class="text-lg mt-4 text-slate-600">
    <slot name="desc">Some description goes here</slot>
  </p>

  <!-- Bottom thin accent line -->
  <div class="flex justify-center mt-6">
    <div class="h-px w-full max-w-3xl" style="background: linear-gradient(90deg, transparent, #003399, transparent);"></div>
  </div>
</div>