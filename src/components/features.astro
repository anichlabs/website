---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "AI Healthcare & Data Strategy",
    description:
      "Leverage AI, machine learning, and data analytics to optimize clinical workflows, research insights, and strategic decisions.",
    icon: "bx:bxs-briefcase",
  },
  {
    title: "Custom Apps & SaaS Solutions",
    description:
      "Build web and mobile applications tailored to healthcare or business needs, integrating data pipelines, dashboards, and automation.",
    icon: "bx:bxs-window-alt",
  },
  {
    title: "Quick & Affordable Websites",
    description:
      "Get professional websites up and running fast with modern frameworks, responsive design, and email integration.",
    icon: "bx:bxs-data",
  },
  {
    title: "Data Analysis & Reporting",
    description:
      "Transform raw health or business data into actionable insights through dashboards, visualizations, and statistical modeling.",
    icon: "bx:bxs-bot",
  },
  {
    title: "AI Model Validation & Deployment",
    description:
      "Ensure your AI models are accurate, compliant, and production-ready for healthcare or enterprise use.",
    icon: "bx:bxs-file-find",
  },
  {
    title: "Consulting & Support",
    description:
      "Guidance on AI, data strategy, app architecture, and digital transformation to accelerate your projects safely and efficiently.",
    icon: "bx:bxs-user",
  },
];
---

<div class="mt-16 md:mt-0">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    Our Services
  </h2>
  <p class="text-lg mt-4 text-slate-600">
    We combine healthcare expertise, AI, and modern web technologies to deliver practical solutions 
    for clinics, startups, and businesses.
  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-16">
  {
    features.map((item) => (
      <div class="flex gap-4 items-start">
        <div class="mt-1 bg-black rounded-full  p-2 w-8 h-8 shrink-0">
          <Icon class="text-white" name={item.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-lg">{item.title}</h3>{" "}
          <p class="text-slate-500 mt-2 leading-relaxed">{item.description}</p>
        </div>
      </div>
    ))
  }
</div>
