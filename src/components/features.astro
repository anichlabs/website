---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "EU Authorised Representative",
    description:
      "Formal EU representation under written mandate for non-EU health-tech companies entering the European market. Required under MDR, IVDR, and the EU AI Act for high-risk systems.",
    icon: "uil:building",
  },
  {
    title: "EU AI Act & MDR Compliance",
    description:
      "Risk classification, technical documentation review, and compliance roadmaps for high-risk medical AI systems under the EU AI Act and Medical Device Regulation.",
    icon: "uil:shield-check",
  },
  {
    title: "GDPR Advisory",
    description:
      "Data protection frameworks, DPIA, Article 27 representation, and GDPR compliance for health data processors operating in or entering the European market.",
    icon: "uil:lock",
  },
  {
    title: "Clinical AI Strategy",
    description:
      "Translating clinical needs into technically sound and regulatorily compliant AI product requirements. Bridging the gap between medical practice and engineering teams.",
    icon: "uil:brain",
  },
  {
    title: "Data Science & Analytics",
    description:
      "Statistical modelling, data pipelines, and dashboards built for healthcare environments with compliance by design and outputs your clinical team can actually use.",
    icon: "uil:chart-line",
  },
  {
    title: "App Development",
    description:
      "GDPR-compliant web and mobile applications for healthcare operators and health-tech companies. Built with clinical workflows and regulatory requirements in mind from day one.",
    icon: "uil:mobile-android",
  },
];
---

<div class="mt-16 md:mt-0">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    How We Help
  </h2>
  <p class="text-lg mt-4 text-slate-600">
    Regulatory expertise, clinical judgment, and technical depth
    everything health-tech companies need to enter and operate in the European market.
  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-16">
  {
    features.map((item) => (
      <div class="flex gap-4 items-start">
        <div class="mt-1 rounded-full p-2 w-8 h-8 shrink-0" style="background-color: #003399">
          <Icon class="text-white" name={item.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-lg">{item.title}</h3>
          <p class="text-slate-500 mt-2 leading-relaxed">{item.description}</p>
        </div>
      </div>
    ))
  }
</div>