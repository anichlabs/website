---
import { Icon } from "astro-icon/components";

const practiceAreas = [
  {
    href: "/services/clinical-ai-strategy",
    title: "AI Systems",
    icon: "uil:brain",
    summary: "Clinical AI, AI agents, and intelligent automation, built EU-sovereign and audit-ready.",
  },
  {
    href: "/services/eu-ai-act-mdr-compliance",
    title: "EU Compliance",
    icon: "uil:shield-check",
    summary: "EU AI Act, MDR, IVDR, and GDPR advisory for companies operating under regulatory scrutiny.",
  },
  {
    href: "/services/data-analytics",
    title: "Data & Analytics",
    icon: "uil:chart-line",
    summary: "Statistical modelling, dashboards, and evidence work for compliance-driven environments.",
  },
  {
    href: "/services/app-development",
    title: "Websites & Apps",
    icon: "uil:browser",
    summary: "Websites, booking systems, automation, and apps for healthcare and growing companies.",
  },
];
---

<div class="mt-16 md:mt-0">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    What We Do
  </h2>
  <p class="text-lg mt-4 text-slate-600 max-w-2xl">
    Four practice areas, one lab. Clinical reasoning, computational depth,
    and EU regulatory expertise applied to healthcare, technology, and
    compliance-driven industries.
  </p>
</div>

<!-- 4-card grid -->
<div class="grid sm:grid-cols-2 mt-12 gap-6">
  {
    practiceAreas.map((area) => (
      <a
        href={area.href}
        class="group flex gap-5 items-start p-6 rounded-2xl border border-slate-200 hover:border-[#003399] hover:shadow-md transition-all bg-white">
        <div class="rounded-full p-3 w-12 h-12 shrink-0 flex items-center justify-center" style="background-color: #003399">
          <Icon class="text-white w-6 h-6" name={area.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-lg text-gray-800 group-hover:text-[#003399] transition-colors">
            {area.title}
          </h3>
          <p class="text-slate-500 mt-2 leading-relaxed text-sm">
            {area.summary}
          </p>
          <span class="inline-flex items-center gap-1 mt-3 text-sm font-semibold group-hover:underline" style="color: #003399">
            Learn more
            <Icon name="uil:arrow-right" class="w-4 h-4" />
          </span>
        </div>
      </a>
    ))
  }
</div>