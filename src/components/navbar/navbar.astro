---
import Container from "@/components/container.astro";
import Link from "@/components/ui/link.astro";
import Dropdown from "./dropdown.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

const menuitems = [
  {
    title: "Services",
    path: "#",
    children: [
      { title: "AI Systems", path: "/services/clinical-ai-strategy" },
      { title: "EU Compliance", path: "/services/eu-ai-act-mdr-compliance" },
      { title: "Data & Analytics", path: "/services/data-analytics" },
      { title: "Websites & Apps", path: "/services/app-development" },
    ],
  },
  {
    title: "About",
    path: "/about",
  },
  {
    title: "Contact",
    path: "/contact",
  },
];
---

<Container>
  <header class="flex flex-col lg:flex-row justify-between items-center my-5">
    <Astronav>
      <div class="flex w-full lg:w-auto items-center justify-between">
        <a href="/" class="text-lg">
          <span class="font-bold text-slate-800">Anich</span><span
            class="text-[#003399]">Labs</span
          ><span class="text-slate-400 text-sm font-normal ml-0.5">OÜ</span>
        </a>
        <div class="block lg:hidden">
          <MenuIcon class="w-4 h-4 text-gray-800" />
        </div>
      </div>
      <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
        <ul class="flex flex-col lg:flex-row lg:gap-3">
          {
            menuitems.map((item, index) => (
              <>
                {item.children && (
                  <Dropdown
                    title={item.title}
                    children={item.children}
                    lastItem={index === menuitems.length - 1}
                  />
                )}
                {!item.children && (
                  <li>
  
                    <a href={item.path}
                    class="flex lg:px-3 py-2 items-center text-gray-600 hover:text-[#003399] transition-colors">
                    <span>{item.title}</span>
                  </a>
                </li>
                )}
              </>
            ))
          }
        </ul>
        <!-- Mobile only: Book a Call button -->
        <div class="lg:hidden flex items-center mt-3 gap-4">
          <Link href="https://calendly.com/chris-anichlabs/30min" target="_blank" rel="noopener" size="md" block>Book a Call</Link>
        </div>
      </MenuItems>
    </Astronav>
    <!-- Desktop only: Book a Call button -->
    <div class="hidden lg:flex items-center gap-4">
      <Link href="https://calendly.com/chris-anichlabs/30min" target="_blank" rel="noopener" size="md">Book a Call</Link>
    </div>
  </header>
</Container>